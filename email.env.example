# Copy to a private file such as /root/docker/bian-web/email.env and fill in values.
# Do not commit real SMTP credentials.

# Common examples:
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_TLS=ssl
# QQ Mail: SMTP_HOST=smtp.qq.com, SMTP_PORT=465, SMTP_TLS=ssl
# 163 Mail: SMTP_HOST=smtp.163.com, SMTP_PORT=465, SMTP_TLS=ssl

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_TLS=ssl
SMTP_USER=sender@example.com
SMTP_PASSWORD=app-password-or-smtp-auth-code
SMTP_FROM=sender@example.com
SMTP_TO=recipient@example.com
EMAIL_SUBJECT=Binance leaderboard exports
EMAIL_BODY=Leaderboard Excel files are attached.
